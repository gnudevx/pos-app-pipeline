        "src/frontend/src/api/productApi.ts"
      ],
      "api_routes": [],
      "cross_service_calls": [],
      "shared_types": [
        "Product"
      ],
      "depends_on": [
        "TASK-03"
      ],
      "task_id": "TASK-06"
    },
    {
      "name": "Cart Backend",
      "component": "backend",
      "entity_refs": [
        "ENT-05"
      ],
      "description": "Manages items in a user's current shopping cart. Requires JWT for all routes.",
      "constraints": [
        "requires_jwt"
      ],
      "storage_type": "in_memory",
      "file_structure": [
        "src/services/cart_backend/app/main.py",
        "src/services/cart_backend/app/routes/cart.py",
        "src/services/cart_backend/app/models/cart.py",
        "src/services/cart_backend/requirements.txt"
      ],
      "api_routes": [
        {
          "method": "POST",
          "path": "/cart/add",
          "status_code": 201,
          "request_body": {
            "product_id": "int",
            "quantity": "int"
          },
          "response_body": "CartItem",
          "errors": [
            {
              "status_code": 404,
              "when": "product not found"
            },
            {
              "status_code": 400,
              "when": "invalid quantity"
            }
          ]
        },
        {
          "method": "PUT",
          "path": "/cart/update/{item_id}",
          "status_code": 200,
          "request_body": {
            "quantity": "int"
          },
          "response_body": "CartItem",
          "errors": [
            {
              "status_code": 404,
              "when": "cart item not found"
            },
            {
              "status_code": 400,
              "when": "invalid quantity"
            }
          ]
        },
        {
          "method": "DELETE",
          "path": "/cart/remove/{item_id}",
          "status_code": 204,
          "request_body": {},
          "response_body": {},
          "errors": [
            {
              "status_code": 404,
              "when": "cart item not found"
            }
          ]
        },
        {
          "method": "GET",
          "path": "/cart",
          "status_code": 200,
          "request_body": {},
          "response_body": {
            "items": "list[CartItem]"
          },
          "errors": []
        },
        {
          "method": "DELETE",
          "path": "/cart/clear",
          "status_code": 204,
          "request_body": {},
          "response_body": {},
          "errors": []
        }
      ],
      "cross_service_calls": [],
      "shared_types": [
        "CartItem"
      ],
      "depends_on": [
        "TASK-01"
      ],
      "source_dir": "src/services/cart_backend",
      "task_id": "TASK-04"
    },
    {
      "name": "Cart Frontend",
      "component": "frontend",
      "entity_refs": [
        "ENT-06"
      ],
      "description": "Displays current cart items, allows quantity adjustments, item removal, and clearing the cart.",
      "constraints": [],
      "storage_type": null,
      "file_structure": [
        "src/frontend/src/pages/CartPage.tsx",
        "src/frontend/src/components/CartItem.tsx",
        "src/frontend/src/api/cartApi.ts"
      ],
      "api_routes": [],
      "cross_service_calls": [],
      "shared_types": [
        "CartItem"
      ],
      "depends_on": [
        "TASK-05"
      ],
      "task_id": "TASK-08"
    },
    {
      "name": "Inventory Backend",
      "component": "backend",
      "entity_refs": [
        "ENT-11"
      ],
      "description": "Tracks and allows manual adjustment of product stock levels. Requires JWT and audit logs.",
      "constraints": [
        "audit_log",
        "requires_jwt"
      ],
      "storage_type": "in_memory",
      "file_structure": [
        "src/services/inventory_backend/app/main.py",
        "src/services/inventory_backend/app/routes/inventory.py",
        "src/services/inventory_backend/app/models/inventory.py",
        "src/services/inventory_backend/requirements.txt"
      ],
      "api_routes": [
        {
          "method": "GET",
          "path": "/inventory",
          "status_code": 200,
          "request_body": {},
          "response_body": {
            "items": "list[InventoryItem]"
          },
          "errors": []
        },
        {
          "method": "PUT",
          "path": "/inventory/{product_id}/adjust",
          "status_code": 200,
          "request_body": {
            "quantity_change": "int"
          },
          "response_body": "InventoryItem",
          "errors": [
            {
              "status_code": 404,
              "when": "product not found"
            },
            {
              "status_code": 400,
              "when": "invalid quantity change or insufficient stock"
            }
          ]
        }
      ],
      "cross_service_calls": [
        {
          "target": "Product Backend",
          "path": "/products/{product_id}",
          "timeout_ms": 1000,
          "on_failure": "error"
        }
      ],
      "shared_types": [
        "InventoryItem"
      ],
      "depends_on": [
        "TASK-01",
        "TASK-03"
      ],
      "source_dir": "src/services/inventory_backend",
      "task_id": "TASK-07"
    },
    {
      "name": "Inventory Frontend",
      "component": "frontend",
      "entity_refs": [
        "ENT-12"
      ],
      "description": "Interface for viewing current stock levels and manually adjusting product stock.",
      "constraints": [],
      "storage_type": null,
      "file_structure": [
        "src/frontend/src/pages/InventoryPage.tsx",
        "src/frontend/src/api/inventoryApi.ts"
      ],
      "api_routes": [],
      "cross_service_calls": [],
      "shared_types": [
        "InventoryItem"
      ],
      "depends_on": [
        "TASK-07"
      ],
      "task_id": "TASK-10"
    },
