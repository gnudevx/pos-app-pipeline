    {
      "name": "Checkout Backend",
      "component": "backend",
      "entity_refs": [
        "ENT-07"
      ],
      "description": "Processes the cart into an order, deducts inventory, and generates a receipt. Requires JWT, audit logs, atomic transactions, and idempotency keys.",
      "constraints": [
        "atomic_transaction",
        "audit_log",
        "idempotency_key",
        "requires_jwt"
      ],
      "storage_type": "in_memory",
      "file_structure": [
        "src/services/checkout_backend/app/main.py",
        "src/services/checkout_backend/app/routes/checkout.py",
        "src/services/checkout_backend/app/models/order.py",
        "src/services/checkout_backend/requirements.txt"
      ],
      "api_routes": [
        {
          "method": "POST",
          "path": "/checkout",
          "status_code": 201,
          "request_body": {
            "payment_info": "dict"
          },
          "response_body": "Order",
          "errors": [
            {
              "status_code": 400,
              "when": "payment failed or insufficient stock"
            },
            {
              "status_code": 404,
              "when": "cart is empty"
            }
          ]
        }
      ],
      "cross_service_calls": [
        {
          "target": "Cart Backend",
          "path": "/cart",
          "timeout_ms": 2000,
          "on_failure": "error"
        },
        {
          "target": "Inventory Backend",
          "path": "/inventory/{product_id}/adjust",
          "timeout_ms": 2000,
          "on_failure": "compensate"
        },
        {
          "target": "Order History Backend",
          "path": "/orders",
          "timeout_ms": 2000,
          "on_failure": "error"
        },
        {
          "target": "Cart Backend",
          "path": "/cart/clear",
          "timeout_ms": 2000,
          "on_failure": "error"
        }
      ],
      "shared_types": [
        "Order",
        "OrderItem"
      ],
      "depends_on": [
        "TASK-01",
        "TASK-05",
        "TASK-07",
        "TASK-09"
      ],
      "source_dir": "src/services/checkout_backend",
      "task_id": "TASK-11"
    },
    {
      "name": "Checkout Frontend",
      "component": "frontend",
      "entity_refs": [
        "ENT-08"
      ],
      "description": "Provides the interface to review the cart and finalize a purchase.",
      "constraints": [],
      "storage_type": null,
