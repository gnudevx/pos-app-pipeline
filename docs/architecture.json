    {
      "name": "Shopping Cart Management Backend",
      "component": "backend",
      "entity_refs": [
        "ENT-05"
      ],
      "description": "Manages items in a user's current shopping cart. Requires JWT for all operations. Cart data is transient.",
      "constraints": [
        "requires_jwt"
      ],
      "storage_type": "in_memory",
      "file_structure": [
        "src/services/shopping_cart_backend/app/main.py",
