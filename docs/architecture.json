          "response_body": {
            "id": "int",
            "user_id": "int",
            "items": [
              {
                "product_id": "int",
                "quantity": "int"
              }
            ]
          },
          "errors": [
            {
              "status_code": 404,
              "when": "item not found in cart"
            },
            {
              "status_code": 400,
              "when": "invalid quantity"
            }
          ],
          "auth_required": true
        },
        {
          "method": "DELETE",
          "path": "/cart/remove/{item_id}",
          "status_code": 204,
          "request_body": {},
          "response_body": {},
          "errors": [
            {
              "status_code": 404,
              "when": "item not found in cart"
            }
