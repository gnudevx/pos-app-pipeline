    {
      "name": "Checkout & Order Processing Backend",
      "component": "backend",
      "entity_refs": [
        "ENT-07"
      ],
      "description": "Processes the cart into an order, deducts inventory, and generates a receipt. Requires JWT. Uses atomic transactions and idempotency keys. Audit logs every write.",
      "constraints": [
        "atomic_transaction",
        "audit_log",
        "idempotency_key",
        "requires_jwt"
      ],
      "storage_type": "in_memory",
      "file_structure": [
        "src/services/checkout_backend/app/main.py",
        "src/services/checkout_backend/app/routes/checkout.py",
        "src/services/checkout_backend/app/models/order.py",
        "src/services/checkout_backend/requirements.txt"
      ],
      "api_routes": [
        {
          "method": "POST",
          "path": "/checkout",
          "status_code": 201,
          "request_body": {
            "cart_id": "int",
            "payment_info": "str"
          },
          "response_body": {
            "id": "int",
            "user_id": "int",
            "items": [
              {
                "product_id": "int",
                "quantity": "int",
                "price_at_purchase": "float"
              }
            ],
            "total_price": "float",
            "status": "str",
            "created_at": "str"
          },
          "errors": [
            {
              "status_code": 400,
              "when": "invalid cart or payment info"
            },
            {
              "status_code": 409,
              "when": "insufficient stock"
            }
          ],
          "auth_required": true
        }
      ],
      "cross_service_calls": [
        {
          "target": "Shopping Cart Management Backend",
          "path": "/cart/clear",
          "method": "DELETE",
          "timeout_ms": 2000,
          "on_failure": "compensate"
        },
        {
          "target": "Inventory Stock Management Backend",
          "path": "/inventory/{product_id}/deduct",
          "method": "PUT",
          "timeout_ms": 5000,
          "on_failure": "compensate"
        }
      ],
      "shared_types": [
        "Order"
      ],
      "depends_on": [
        "TASK-01",
        "TASK-05",
        "TASK-11"
      ],
      "source_dir": "src/services/checkout_backend",
      "task_id": "TASK-08"
    },
