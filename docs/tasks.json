          "id": "TASK-01",
          "story_ref": "US-01",
          "summary": "Backend API: Products and Cart endpoints",
          "description": "Implement FastAPI backend with in-memory storage. Endpoints: GET /health, GET/POST/PUT/DELETE /products/, POST /cart/add, GET /cart/, DELETE /cart/clear, POST /cart/checkout. Use Pydantic v2 models. Configure CORS to allow all origins.",
          "story_points": 5,
          "priority": "P0",
          "status": "DONE",
          "component": "backend",
          "dependencies": [],
          "api_contract": {
            "routes": [
              {
                "method": "GET",
                "path": "/health",
                "status_code": 200
              },
              {
                "method": "POST",
                "path": "/products/",
                "status_code": 201
              },
              {
                "method": "GET",
                "path": "/products/",
                "status_code": 200,
                "response_example": {
                  "items": [
                    {
                      "id": 1,
                      "name": "Coffee",
                      "price": 10.0,
                      "stock": 5
                    }
                  ]
                }
              },
              {
                "method": "GET",
                "path": "/products/{id}",
                "status_code": 200
              },
              {
                "method": "PUT",
                "path": "/products/{id}",
                "status_code": 200
              },
              {
                "method": "DELETE",
                "path": "/products/{id}",
                "status_code": 204
              },
              {
                "method": "POST",
                "path": "/cart/add",
                "status_code": 201
              },
              {
                "method": "GET",
                "path": "/cart/",
                "status_code": 200
              },
              {
                "method": "DELETE",
                "path": "/cart/clear",
                "status_code": 204
              },
              {
                "method": "POST",
                "path": "/cart/checkout",
                "status_code": 200
              }
            ]
          },
          "artifacts": [
            "src/backend/app/main.py",
            "src/backend/app/routes/products.py",
            "src/backend/app/routes/cart.py",
            "src/backend/app/models/product.py",
            "src/backend/requirements.txt"
          ],
          "acceptance_criteria": [
            "GET /health returns status ok",
            "Products CRUD endpoints work correctly (create, read, update, delete)",
            "Cart add, clear, and checkout flows work as expected",
            "All API responses use Pydantic v2 models for validation",
            "Application runs with uvicorn and uses in-memory storage",
            "CORS is configured to allow frontend access"
          ],
          "branch": "feature/task-01-backend-api-products-and-cart-endpoints"
        },
        {
          "id": "TASK-02",
          "story_ref": "US-02",
          "summary": "Frontend UI: React POS interface",
          "description": "Implement React 18 + TypeScript frontend. Build ProductCard, Cart, and AddProductForm components. Integrate App.tsx and connect frontend to backend using fetch API to display products, manage cart, and handle checkout.",
          "story_points": 5,
          "priority": "P0",
          "status": "DONE",
          "component": "frontend",
          "dependencies": [
            "TASK-01"
          ],
          "artifacts": [
            "src/frontend/src/App.tsx",
            "src/frontend/src/components/ProductCard.tsx",
            "src/frontend/src/components/Cart.tsx",
            "src/frontend/src/components/AddProductForm.tsx",
            "src/frontend/src/api/client.ts"
          ],
          "acceptance_criteria": [
            "Products are displayed clearly on the UI with relevant information",
            "Users can add products to a cart, view cart contents, and adjust quantities",
            "The checkout flow is intuitive and allows for completing a sale",
            "Frontend successfully integrates and communicates with the backend APIs",
            "UI is responsive and user-friendly"
          ],
          "branch": "feature/task-02-frontend-ui-react-pos-interface"
        },
