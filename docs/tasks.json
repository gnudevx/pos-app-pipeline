          "acceptance_criteria": [
            "GET /health returns status ok",
            "Products CRUD endpoints work correctly with in-memory storage",
            "Cart add, clear, and checkout flows work with in-memory storage",
            "All API requests and responses use Pydantic v2 models",
            "CORS is configured to allow frontend access",
            "Application runs with uvicorn"
          ]
        },
