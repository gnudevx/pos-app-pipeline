              },
              {
                "method": "get",
                "path": "/products/{id}",
                "status_code": 200,
                "response_fields": {
                  "id": "int",
                  "name": "str",
                  "price": "float",
                  "stock": "int"
                }
              },
              {
                "method": "put",
                "path": "/products/{id}",
                "status_code": 200,
                "response_fields": {}
              },
              {
                "method": "delete",
                "path": "/products/{id}",
                "status_code": 204,
                "response_fields": {}
              },
              {
                "method": "post",
                "path": "/cart/add",
                "status_code": 201,
                "response_fields": {
                  "product_id": "int",
                  "quantity": "int"
                }
              },
              {
                "method": "get",
                "path": "/cart",
                "status_code": 200,
                "response_fields": {
                  "items": "list"
                }
              },
              {
                "method": "delete",
                "path": "/cart/clear",
                "status_code": 204,
                "response_fields": {}
              },
              {
                "method": "post",
                "path": "/cart/checkout",
                "status_code": 200,
                "response_fields": {
                  "id": "int",
                  "total": "float"
                }
              }
            ]
          },
          "artifacts": [
            "src/backend/app/main.py",
            "src/backend/app/routes/products.py",
            "src/backend/app/routes/cart.py",
            "src/backend/app/models/product.py",
            "src/backend/app/models/cart.py",
            "src/backend/requirements.txt"
