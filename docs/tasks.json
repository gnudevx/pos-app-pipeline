          "priority": "P0",
          "status": "TODO",
          "component": "backend",
          "dependencies": [],
          "api_contract": {
            "routes": [
              {
                "method": "get",
                "path": "/health",
                "status_code": 200,
                "response_fields": {
                  "status": "str"
                }
              },
              {
                "method": "post",
                "path": "/products",
                "status_code": 201,
                "response_fields": {
                  "id": "int",
                  "name": "str",
                  "price": "float",
                  "stock": "int"
                }
              },
              {
                "method": "get",
                "path": "/products",
